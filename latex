\section{Contexte général}

\begin{frame}{Contexte général}
Les réseaux sociaux occupent une place centrale dans la vie des étudiants.

\begin{itemize}
    \item Communication rapide
    \item Partage d'informations
    \item Accès aux ressources éducatives
\end{itemize}
\end{frame}

%--------Notre question principale est :
%Les réseaux sociaux ont-ils un impact positif ou négatif sur la réussite académique ?

\section{Question de recherche}

\begin{frame}{Question de recherche}
\centering
\Large
Les réseaux sociaux influencent-ils positivement ou négativement la réussite académique ?
\end{frame}

%-----------Nous avons réalisé une étude quantitative exploratoire.
% Nous avons analysé trois étudiants en observant :

\section{Méthode d'étude}

\begin{frame}{Méthode d'étude}
\begin{itemize}
    \item Étude quantitative exploratoire
    \item Échantillon : 3 étudiants
    \item Variables analysées :
    \begin{itemize}
        \item Temps quotidien passé sur les réseaux sociaux
        \item Réseau dominant
        \item Type d'utilisation
        \item Moyenne académique (/20)
        \item Heures de sommeil
    \end{itemize}
    \item Analyse descriptive comparative
\end{itemize}
\end{frame}

%----Les résultats montrent que l’étudiant qui passe le plus de temps sur les réseaux sociaux pour le divertissement a la moyenne la plus faible.
%En revanche, les étudiants qui utilisent les réseaux à des fins éducatives obtiennent de meilleures moyennes.

